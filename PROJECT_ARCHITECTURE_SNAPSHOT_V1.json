        "formulas_implemented": [
          "Surface Area: kAS × Weight^0.425 × Height^0.725 / 10000",
          "Skin Thickness: Surface Area × tSkin × 1.05",
          "Adipose: 5.85 × sum6 + 25.6",
          "Muscle: 5.4 × sumCorrectedPerimeters + 24.5",
          "Residual: 1.24 × zScore + 6.1",
          "Bone: 1.34 × zScore + 6.7",
          "Z-score: (measured - phantom_mean) / phantom_sd",
          "Indices: muscle/bone, adipose/muscle, ballast ratios"
        ]
      },
