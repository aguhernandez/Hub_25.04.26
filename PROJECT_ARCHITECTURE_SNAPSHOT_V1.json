          "description": "Ross & Wilson reference phantom used for Z-score calculations",
          "adipose_mass_mean_kg": 116.41,
          "adipose_mass_sd_kg": 34.79,
          "muscle_mass_mean_kg": 207.21,
          "muscle_mass_sd_kg": 13.74,
