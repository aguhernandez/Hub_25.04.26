<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>Asciende</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>

	<!-- Background Modes: GPS tracking + Push Notifications -->
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
		<string>fetch</string>
		<string>remote-notification</string>
	</array>

	<!-- Camera -->
	<key>NSCameraUsageDescription</key>
	<string>Asciende needs access to your camera for exercise video analysis and form assessment</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Asciende needs access to your photo library to select images for your profile and training</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Asciende saves your workout summaries to your photo library</string>

	<!-- Location / GPS -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Asciende needs your location to record GPS activities and track outdoor training routes</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Asciende needs continuous location access to keep recording your training route even when the app is in the background</string>
	<key>NSLocationAlwaysUsageDescription</key>
	<string>Asciende needs background location access to continue recording GPS activities while the screen is off</string>

	<!-- Motion -->
	<key>NSMotionUsageDescription</key>
	<string>Asciende uses motion data to improve activity tracking accuracy</string>

	<!-- Deep Link / OAuth URL Scheme -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>pro.asciende.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>pro.asciende.app</string>
			</array>
		</dict>
	</array>

	<!-- Queried URL Schemes (Instagram Stories) -->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>instagram-stories</string>
		<string>instagram</string>
	</array>

	<!-- App Transport Security (allow HTTPS by default, no cleartext) -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>

	<!-- Firebase: enable method swizzling so Firebase auto-captures APNs token -->
	<key>FirebaseAppDelegateProxyEnabled</key>
	<true/>

	<!-- App Store compliance: no non-exempt encryption -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>
