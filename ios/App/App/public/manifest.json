{
  "id": "/",
  "name": "Asciende - The Athlete's Support Platform",
  "short_name": "Asciende",
  "description": "Professional platform for athletes to track training, nutrition, and performance with expert guidance",
  "start_url": "/?source=pwa",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "background_color": "#0C0D0F",
  "theme_color": "#0C0D0F",
  "orientation": "portrait-primary",
  "categories": ["sports", "health", "fitness"],
  "prefer_related_applications": false,
  "lang": "es",
  "dir": "ltr",
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/favicon.png",
      "sizes": "64x64",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "screenshots": [
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Asciende Dashboard"
    }
  ],
  "shortcuts": [
    {
      "name": "Entrenamiento",
      "short_name": "Entreno",
      "description": "Accede a tu plan de entrenamiento",
      "url": "/training?source=shortcut",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Nutrición",
      "short_name": "Nutrición",
      "description": "Registra tu alimentación",
      "url": "/nutrition?source=shortcut",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Perfil",
      "short_name": "Perfil",
      "description": "Ver tu perfil atlético",
      "url": "/athlete-profile?source=shortcut",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": "navigate-existing"
  }
